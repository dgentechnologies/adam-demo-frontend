# Vercel Environment Variables — DGEN Website Frontend
# Copy this to .env.local for local development. Never commit actual secrets.

# ── Firebase Client SDK (public — safe in browser) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ── Firebase Admin SDK (server-side only — NEVER expose to browser) ───────────
# Get from: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Keep newlines escaped as \n (Vercel handles this automatically)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Relay JWT Secret (must match RELAY_JWT_SECRET on Railway exactly) ─────────
RELAY_JWT_SECRET=4zHi1D7nYngroI9sC7MOX1QQkkiil5l7PUTqyvfM+cU=    # openssl rand -base64 32

# ── Relay WebSocket URL (public — browser connects here) ──────────────────────
NEXT_PUBLIC_RELAY_URL=wss://adam-relay.railway.app
# For local dev: NEXT_PUBLIC_RELAY_URL=ws://localhost:8080

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SHOW_ADAM_PRODUCT=false   # Set true to show ADAM card on /products
